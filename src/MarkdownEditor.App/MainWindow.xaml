<Window x:Class="MarkdownEditor.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MarkdownEditor.App"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="{Binding WindowTitle}"
        Height="820" Width="1280"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">

    <Window.Resources>
        <Style x:Key="RibbonButtonBase" TargetType="ButtonBase">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="MinWidth" Value="32" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="1,0" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="RibbonButton" TargetType="Button" BasedOn="{StaticResource RibbonButtonBase}" />
        <Style x:Key="RibbonToggle" TargetType="ToggleButton" BasedOn="{StaticResource RibbonButtonBase}" />
        <Style x:Key="GroupLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="#FF777777" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>
        <Style x:Key="RibbonGroup" TargetType="Border">
            <Setter Property="BorderBrush" Value="#FFDDDDDD" />
            <Setter Property="BorderThickness" Value="0,0,1,0" />
            <Setter Property="Padding" Value="6,2" />
        </Style>
    </Window.Resources>

    <Window.CommandBindings>
        <CommandBinding Command="New" Executed="New_Executed" />
        <CommandBinding Command="Open" Executed="Open_Executed" />
        <CommandBinding Command="Save" Executed="Save_Executed" />
        <CommandBinding Command="SaveAs" Executed="SaveAs_Executed" />

        <CommandBinding Command="{x:Static local:EditorCommands.Bold}" Executed="Formatting_Executed" />
        <CommandBinding Command="{x:Static local:EditorCommands.Italic}" Executed="Formatting_Executed" />
        <CommandBinding Command="{x:Static local:EditorCommands.Strikethrough}" Executed="Formatting_Executed" />
        <CommandBinding Command="{x:Static local:EditorCommands.InlineCode}" Executed="Formatting_Executed" />
        <CommandBinding Command="{x:Static local:EditorCommands.Highlight}" Executed="Formatting_Executed" />
        <CommandBinding Command="{x:Static local:EditorCommands.Heading1}" Executed="Formatting_Executed" />
        <CommandBinding Command="{x:Static local:EditorCommands.Heading2}" Executed="Formatting_Executed" />
        <CommandBinding Command="{x:Static local:EditorCommands.Heading3}" Executed="Formatting_Executed" />
        <CommandBinding Command="{x:Static local:EditorCommands.Heading4}" Executed="Formatting_Executed" />
        <CommandBinding Command="{x:Static local:EditorCommands.Heading5}" Executed="Formatting_Executed" />
        <CommandBinding Command="{x:Static local:EditorCommands.Heading6}" Executed="Formatting_Executed" />
        <CommandBinding Command="{x:Static local:EditorCommands.ClearHeading}" Executed="Formatting_Executed" />
        <CommandBinding Command="{x:Static local:EditorCommands.BulletList}" Executed="Formatting_Executed" />
        <CommandBinding Command="{x:Static local:EditorCommands.NumberedList}" Executed="Formatting_Executed" />
        <CommandBinding Command="{x:Static local:EditorCommands.TaskList}" Executed="Formatting_Executed" />
        <CommandBinding Command="{x:Static local:EditorCommands.Blockquote}" Executed="Formatting_Executed" />
        <CommandBinding Command="{x:Static local:EditorCommands.CodeBlock}" Executed="Formatting_Executed" />
        <CommandBinding Command="{x:Static local:EditorCommands.HorizontalRule}" Executed="Formatting_Executed" />
        <CommandBinding Command="{x:Static local:EditorCommands.InsertLink}" Executed="InsertLink_Executed" />
        <CommandBinding Command="{x:Static local:EditorCommands.InsertImage}" Executed="InsertImage_Executed" />
        <CommandBinding Command="{x:Static local:EditorCommands.InsertTable}" Executed="InsertTableDialog_Executed" />
        <CommandBinding Command="{x:Static local:EditorCommands.Find}" Executed="Find_Executed" />
        <CommandBinding Command="{x:Static local:EditorCommands.Replace}" Executed="Replace_Executed" />
        <CommandBinding Command="{x:Static local:EditorCommands.FindNext}" Executed="FindNext_Executed" />
        <CommandBinding Command="{x:Static local:EditorCommands.FindPrevious}" Executed="FindPrevious_Executed" />
    </Window.CommandBindings>

    <Window.InputBindings>
        <KeyBinding Command="SaveAs" Key="S" Modifiers="Ctrl+Shift" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Menu -->
        <Menu Grid.Row="0">
            <MenuItem Header="_File">
                <MenuItem Header="_New" Command="New" InputGestureText="Ctrl+N" />
                <MenuItem Header="_Open…" Command="Open" InputGestureText="Ctrl+O" />
                <MenuItem x:Name="RecentMenu" Header="Open _Recent" SubmenuOpened="RecentMenu_SubmenuOpened">
                    <MenuItem Header="(empty)" IsEnabled="False" />
                </MenuItem>
                <Separator />
                <MenuItem Header="_Save" Command="Save" InputGestureText="Ctrl+S" />
                <MenuItem Header="Save _As…" Command="SaveAs" InputGestureText="Ctrl+Shift+S" />
                <Separator />
                <MenuItem Header="E_xit" Click="Exit_Click" />
            </MenuItem>
        </Menu>

        <!-- Ribbon toolbox -->
        <TabControl Grid.Row="1" Padding="0" BorderThickness="0,0,0,1" Background="#FFFAFAFA">

            <!-- HOME -->
            <TabItem Header="Home">
                <StackPanel Orientation="Horizontal" Height="58">

                    <Border Style="{StaticResource RibbonGroup}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource RibbonButton}" Click="Paste_Click" ToolTip="Paste (Ctrl+V)">📋</Button>
                                <Button Style="{StaticResource RibbonButton}" Click="Cut_Click" ToolTip="Cut (Ctrl+X)">✂</Button>
                                <Button Style="{StaticResource RibbonButton}" Click="Copy_Click" ToolTip="Copy (Ctrl+C)">⧉</Button>
                                <Button Style="{StaticResource RibbonButton}" Click="Undo_Click" ToolTip="Undo (Ctrl+Z)">↶</Button>
                                <Button Style="{StaticResource RibbonButton}" Click="Redo_Click" ToolTip="Redo (Ctrl+Y)">↷</Button>
                            </StackPanel>
                            <TextBlock Style="{StaticResource GroupLabel}" Text="Clipboard" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource RibbonGroup}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource RibbonButton}" Command="{x:Static local:EditorCommands.Bold}" ToolTip="Bold (Ctrl+B)">
                                    <TextBlock Text="B" FontWeight="Bold" />
                                </Button>
                                <Button Style="{StaticResource RibbonButton}" Command="{x:Static local:EditorCommands.Italic}" ToolTip="Italic (Ctrl+I)">
                                    <TextBlock Text="I" FontStyle="Italic" FontFamily="Georgia" />
                                </Button>
                                <Button Style="{StaticResource RibbonButton}" Command="{x:Static local:EditorCommands.Strikethrough}" ToolTip="Strikethrough (Ctrl+Shift+X)">
                                    <TextBlock Text="ab" TextDecorations="Strikethrough" />
                                </Button>
                                <Button Style="{StaticResource RibbonButton}" Command="{x:Static local:EditorCommands.InlineCode}" ToolTip="Inline code (Ctrl+Shift+C)">
                                    <TextBlock Text="&lt;/&gt;" FontFamily="Consolas" />
                                </Button>
                                <Button Style="{StaticResource RibbonButton}" Command="{x:Static local:EditorCommands.Highlight}" ToolTip="Highlight (Ctrl+Shift+H)">
                                    <TextBlock Text="ab" Background="#FFFFF176" Padding="2,0" />
                                </Button>
                            </StackPanel>
                            <TextBlock Style="{StaticResource GroupLabel}" Text="Font" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource RibbonGroup}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <ComboBox x:Name="HeadingCombo" Width="110" Height="26" Focusable="False"
                                          VerticalAlignment="Center" Margin="1,0"
                                          SelectionChanged="HeadingCombo_SelectionChanged"
                                          ToolTip="Heading style (Ctrl+1…6, Ctrl+0 = normal)">
                                    <ComboBoxItem Content="Normal text" />
                                    <ComboBoxItem Content="Heading 1" />
                                    <ComboBoxItem Content="Heading 2" />
                                    <ComboBoxItem Content="Heading 3" />
                                    <ComboBoxItem Content="Heading 4" />
                                    <ComboBoxItem Content="Heading 5" />
                                    <ComboBoxItem Content="Heading 6" />
                                </ComboBox>
                                <Button Style="{StaticResource RibbonButton}" Command="{x:Static local:EditorCommands.BulletList}" ToolTip="Bullet list (Ctrl+Shift+8)">
                                    <TextBlock Text="•―" />
                                </Button>
                                <Button Style="{StaticResource RibbonButton}" Command="{x:Static local:EditorCommands.NumberedList}" ToolTip="Numbered list (Ctrl+Shift+7)">
                                    <TextBlock Text="1." />
                                </Button>
                                <Button Style="{StaticResource RibbonButton}" Command="{x:Static local:EditorCommands.TaskList}" ToolTip="Task list (Ctrl+Shift+9)">
                                    <TextBlock Text="☑" />
                                </Button>
                                <Button Style="{StaticResource RibbonButton}" Command="{x:Static local:EditorCommands.Blockquote}" ToolTip="Blockquote (Ctrl+Shift+Q)">
                                    <TextBlock Text="❝" FontSize="16" />
                                </Button>
                            </StackPanel>
                            <TextBlock Style="{StaticResource GroupLabel}" Text="Paragraph" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource RibbonGroup}" BorderThickness="0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource RibbonButton}" Command="{x:Static local:EditorCommands.Find}" ToolTip="Find (Ctrl+F)" Padding="8,2">Find</Button>
                                <Button Style="{StaticResource RibbonButton}" Command="{x:Static local:EditorCommands.Replace}" ToolTip="Replace (Ctrl+H)" Padding="8,2">Replace</Button>
                                <Button Style="{StaticResource RibbonButton}" Click="SelectAll_Click" ToolTip="Select all (Ctrl+A)" Padding="8,2">Select All</Button>
                            </StackPanel>
                            <TextBlock Style="{StaticResource GroupLabel}" Text="Editing" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </TabItem>

            <!-- INSERT -->
            <TabItem Header="Insert">
                <StackPanel Orientation="Horizontal" Height="58">

                    <Border Style="{StaticResource RibbonGroup}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <ToggleButton x:Name="TableDropdownButton" Style="{StaticResource RibbonToggle}" Padding="8,2" ToolTip="Insert a table">
                                    <TextBlock Text="▦ Table ▾" />
                                </ToggleButton>
                                <Popup x:Name="TablePopup"
                                       PlacementTarget="{Binding ElementName=TableDropdownButton}"
                                       Placement="Bottom"
                                       IsOpen="{Binding IsChecked, ElementName=TableDropdownButton, Mode=TwoWay}"
                                       StaysOpen="False">
                                    <Border Background="White" BorderBrush="#FFCCCCCC" BorderThickness="1" Padding="8">
                                        <StackPanel>
                                            <TextBlock x:Name="TablePickerLabel" Text="Insert table" Margin="0,0,0,6" />
                                            <UniformGrid x:Name="TablePickerGrid" Rows="8" Columns="10" />
                                            <Separator Margin="0,6" />
                                            <Button Content="Insert Table…" Command="{x:Static local:EditorCommands.InsertTable}"
                                                    HorizontalAlignment="Stretch" Padding="4,2" Focusable="False" />
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </StackPanel>
                            <TextBlock Style="{StaticResource GroupLabel}" Text="Tables" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource RibbonGroup}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource RibbonButton}" Command="{x:Static local:EditorCommands.InsertLink}" ToolTip="Insert link (Ctrl+K)" Padding="8,2">🔗 Link</Button>
                                <Button Style="{StaticResource RibbonButton}" Command="{x:Static local:EditorCommands.InsertImage}" ToolTip="Insert image (Ctrl+Shift+I)" Padding="8,2">🖼 Image</Button>
                            </StackPanel>
                            <TextBlock Style="{StaticResource GroupLabel}" Text="Links" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource RibbonGroup}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="CodeBlockButton" Style="{StaticResource RibbonButton}" Click="CodeBlock_Click" ToolTip="Code block with language (Ctrl+Shift+K)" Padding="8,2">
                                    <TextBlock Text="{}{ } Code ▾" FontFamily="Consolas" />
                                </Button>
                                <Button Style="{StaticResource RibbonButton}" Command="{x:Static local:EditorCommands.HorizontalRule}" ToolTip="Horizontal rule" Padding="8,2">― Rule</Button>
                                <Button Style="{StaticResource RibbonButton}" Click="Footnote_Click" ToolTip="Insert footnote" Padding="8,2">x¹ Footnote</Button>
                            </StackPanel>
                            <TextBlock Style="{StaticResource GroupLabel}" Text="Blocks" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource RibbonGroup}" BorderThickness="0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource RibbonButton}" Click="InsertDate_Click" ToolTip="Insert date and time" Padding="8,2">📅 Date</Button>
                                <Button x:Name="EmojiButton" Style="{StaticResource RibbonButton}" Click="Emoji_Click" ToolTip="Insert emoji" Padding="8,2">😀 Emoji ▾</Button>
                            </StackPanel>
                            <TextBlock Style="{StaticResource GroupLabel}" Text="Symbols" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </TabItem>

            <!-- VIEW -->
            <TabItem Header="View">
                <StackPanel Orientation="Horizontal" Height="58">

                    <Border Style="{StaticResource RibbonGroup}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Height="30">
                                <RadioButton x:Name="ViewSplit" Content="Split" IsChecked="True" Checked="ViewMode_Changed" Margin="4,0" VerticalAlignment="Center" Focusable="False" />
                                <RadioButton x:Name="ViewEditorOnly" Content="Editor" Checked="ViewMode_Changed" Margin="4,0" VerticalAlignment="Center" Focusable="False" />
                                <RadioButton x:Name="ViewPreviewOnly" Content="Preview" Checked="ViewMode_Changed" Margin="4,0" VerticalAlignment="Center" Focusable="False" />
                            </StackPanel>
                            <TextBlock Style="{StaticResource GroupLabel}" Text="Layout" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource RibbonGroup}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Height="30">
                                <CheckBox x:Name="SyncScrollCheck" Content="Sync scrolling" IsChecked="True" VerticalAlignment="Center" Margin="4,0" Focusable="False" />
                                <ToggleButton x:Name="DarkThemeToggle" Style="{StaticResource RibbonToggle}" Content="🌙 Dark preview"
                                              Checked="Theme_Changed" Unchecked="Theme_Changed" Padding="8,2" />
                            </StackPanel>
                            <TextBlock Style="{StaticResource GroupLabel}" Text="Preview" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource RibbonGroup}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource RibbonButton}" Click="FontSizeDown_Click" ToolTip="Smaller editor font">A−</Button>
                                <Button Style="{StaticResource RibbonButton}" Click="FontSizeUp_Click" ToolTip="Larger editor font">A+</Button>
                            </StackPanel>
                            <TextBlock Style="{StaticResource GroupLabel}" Text="Editor font" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource RibbonGroup}" BorderThickness="0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <ToggleButton x:Name="OutlineToggle" Style="{StaticResource RibbonToggle}" Content="☰ Outline"
                                              Checked="OutlineToggle_Changed" Unchecked="OutlineToggle_Changed" Padding="8,2" />
                            </StackPanel>
                            <TextBlock Style="{StaticResource GroupLabel}" Text="Panels" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </TabItem>

            <!-- EXPORT (wired in Phase 5) -->
            <TabItem Header="Export">
                <StackPanel Orientation="Horizontal" Height="58">
                    <Border Style="{StaticResource RibbonGroup}" BorderThickness="0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="ExportPdfButton" Style="{StaticResource RibbonButton}" Click="ExportPdf_Click" ToolTip="Export the document as PDF" Padding="8,2">📄 Export to PDF…</Button>
                                <Button x:Name="ExportHtmlButton" Style="{StaticResource RibbonButton}" Click="ExportHtml_Click" ToolTip="Export as standalone HTML" Padding="8,2">🌐 Export to HTML…</Button>
                                <Button x:Name="PrintButton" Style="{StaticResource RibbonButton}" Click="Print_Click" ToolTip="Print (Ctrl+P)" Padding="8,2">🖨 Print…</Button>
                            </StackPanel>
                            <TextBlock Style="{StaticResource GroupLabel}" Text="Export" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- Find / Replace panel -->
        <Border x:Name="FindPanel" Grid.Row="2" Visibility="Collapsed" Background="#FFF5F5F5"
                BorderBrush="#FFDDDDDD" BorderThickness="0,0,0,1" Padding="6,4">
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="FindBox" Width="220" VerticalContentAlignment="Center" KeyDown="FindBox_KeyDown" />
                <Button Content="Next" Click="FindNextBtn_Click" Margin="4,0,0,0" Padding="8,2" Focusable="False" />
                <Button Content="Previous" Click="FindPrevBtn_Click" Margin="4,0,0,0" Padding="8,2" Focusable="False" />
                <TextBox x:Name="ReplaceBox" Width="220" Margin="16,0,0,0" VerticalContentAlignment="Center" />
                <Button Content="Replace" Click="ReplaceBtn_Click" Margin="4,0,0,0" Padding="8,2" Focusable="False" />
                <Button Content="Replace All" Click="ReplaceAllBtn_Click" Margin="4,0,0,0" Padding="8,2" Focusable="False" />
                <CheckBox x:Name="MatchCaseCheck" Content="Match case" VerticalAlignment="Center" Margin="16,0,0,0" Focusable="False" />
                <TextBlock x:Name="FindStatus" VerticalAlignment="Center" Margin="16,0,0,0" Foreground="#FF777777" />
                <Button Content="✕" Click="CloseFindPanel_Click" Margin="16,0,0,0" Padding="6,2" Focusable="False" />
            </StackPanel>
        </Border>

        <!-- Outline / editor / preview split -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="OutlineColumn" Width="0" />
                <ColumnDefinition x:Name="EditorColumn" Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition x:Name="PreviewColumn" Width="*" />
            </Grid.ColumnDefinitions>

            <ListBox x:Name="OutlineList"
                     Grid.Column="0"
                     BorderThickness="0,0,1,0"
                     BorderBrush="#FFDDDDDD"
                     SelectionChanged="OutlineList_SelectionChanged" />

            <avalonEdit:TextEditor x:Name="Editor"
                                   Grid.Column="1"
                                   FontFamily="Cascadia Code, Consolas"
                                   FontSize="14"
                                   ShowLineNumbers="True"
                                   WordWrap="True"
                                   HorizontalScrollBarVisibility="Disabled"
                                   VerticalScrollBarVisibility="Auto"
                                   Padding="8,4" />

            <GridSplitter x:Name="Splitter"
                          Grid.Column="2"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="#FFE0E0E0"
                          ShowsPreview="False" />

            <wv2:WebView2 x:Name="Preview"
                          Grid.Column="3"
                          DefaultBackgroundColor="White" />
        </Grid>

        <!-- Status bar -->
        <StatusBar Grid.Row="4">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusInfo}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding CaretInfo}" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
