<Window x:Class="MarkdownEditor.App.Views.InsertImageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Insert Image"
        SizeToContent="Height" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Content="_Image:" Target="{Binding ElementName=PathBox}" VerticalAlignment="Center" />
        <TextBox x:Name="PathBox" Grid.Row="0" Grid.Column="1" Margin="4" Padding="2" />
        <Button Grid.Row="0" Grid.Column="2" Content="_Browse…" Click="Browse_Click" Margin="4" Padding="8,2" />

        <Label Grid.Row="1" Grid.Column="0" Content="_Alt text:" Target="{Binding ElementName=AltBox}" VerticalAlignment="Center" />
        <TextBox x:Name="AltBox" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="4" Padding="2" />

        <StackPanel Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="OK" IsDefault="True" Click="Ok_Click" Width="80" Margin="0,0,8,0" />
            <Button Content="Cancel" IsCancel="True" Width="80" />
        </StackPanel>
    </Grid>
</Window>
