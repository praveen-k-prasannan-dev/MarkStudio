<Window x:Class="MarkdownEditor.App.Views.ExportPdfDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export to PDF"
        SizeToContent="Height" Width="340"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Content="Page size:" VerticalAlignment="Center" />
        <ComboBox x:Name="PageSizeCombo" Grid.Row="0" Grid.Column="1" Margin="4" SelectedIndex="0">
            <ComboBoxItem Content="A4" />
            <ComboBoxItem Content="Letter" />
        </ComboBox>

        <Label Grid.Row="1" Grid.Column="0" Content="Orientation:" VerticalAlignment="Center" />
        <ComboBox x:Name="OrientationCombo" Grid.Row="1" Grid.Column="1" Margin="4" SelectedIndex="0">
            <ComboBoxItem Content="Portrait" />
            <ComboBoxItem Content="Landscape" />
        </ComboBox>

        <Label Grid.Row="2" Grid.Column="0" Content="Margins:" VerticalAlignment="Center" />
        <ComboBox x:Name="MarginsCombo" Grid.Row="2" Grid.Column="1" Margin="4" SelectedIndex="1">
            <ComboBoxItem Content="Narrow (0.4&quot;)" />
            <ComboBoxItem Content="Normal (0.75&quot;)" />
            <ComboBoxItem Content="Wide (1&quot;)" />
        </ComboBox>

        <CheckBox x:Name="BackgroundsCheck" Grid.Row="3" Grid.Column="1" Margin="4,8"
                  Content="Print background colors" IsChecked="True" />

        <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Export" IsDefault="True" Click="Ok_Click" Width="80" Margin="0,0,8,0" />
            <Button Content="Cancel" IsCancel="True" Width="80" />
        </StackPanel>
    </Grid>
</Window>
